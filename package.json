{
  "name": "ai-flashcard",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop-first AI flashcard tool for Obsidian",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "build": "npm run build:electron && npm run build:renderer",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.electron.json && tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "wait-on": "^9.0.1"
  }
}
